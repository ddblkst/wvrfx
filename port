    function initTooltips() {
        let activeTooltip = null;
        let activeTrigger = null;

        function positionTooltip(tooltip, trigger) {
            const rect = trigger.getBoundingClientRect();
            let left = rect.left + (rect.width / 2) - 20;
            let top = rect.bottom + 8 + window.scrollY;

            // Keep within horizontal bounds
            if (left < 5) left = 5;
            if (left + 280 > window.innerWidth) left = window.innerWidth - 290;

            // If tooltip would go below viewport, show above
            if (rect.bottom + 80 > window.innerHeight) {
                top = rect.top - 10 + window.scrollY - tooltip.offsetHeight;
            }

            tooltip.style.left = left + 'px';
            tooltip.style.top = top + 'px';
        }

        function removeTooltip() {
            if (activeTooltip) {
                activeTooltip.remove();
                activeTooltip = null;
                activeTrigger = null;
            }
        }

        // Handle scroll — reposition tooltip
        window.addEventListener('scroll', () => {
            if (activeTooltip && activeTrigger) {
                positionTooltip(activeTooltip, activeTrigger);
            }
        }, { passive: true });

        // Handle resize — reposition tooltip
        window.addEventListener('resize', () => {
            if (activeTooltip && activeTrigger) {
                positionTooltip(activeTooltip, activeTrigger);
            }
        });

        document.addEventListener('click', function(e) {
            const qmark = e.target.closest('.qmark-tip');
            
            // If clicking the same trigger, just close
            if (qmark && qmark === activeTrigger) {
                removeTooltip();
                return;
            }

            // Remove existing tooltip
            removeTooltip();

            // If clicked on a qmark, show tooltip
            if (qmark) {
                e.stopPropagation();
                const tipText = qmark.getAttribute('data-tip');
                if (!tipText) return;

                const div = document.createElement('div');
                div.className = 'weaver-tooltip';
                div.innerText = tipText;
                document.body.appendChild(div);

                activeTooltip = div;
                activeTrigger = qmark;

                positionTooltip(div, qmark);
            }
        });

        // Close tooltip on Escape key
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') {
                removeTooltip();
            }
        });
    }

