        } finally {
            deployBtn.disabled = false;
            spinnerWebLeft.style.display = 'none';
            spinnerWebRight.style.display = 'none';
            btnText.innerHTML = originalBtnTextContent;
            setTimeout(() => {
                if(statusDiv.innerHTML === '<span class="status-success">✅ Config shipped successfully</span>') {
                    setTimeout(() => { statusDiv.innerHTML = ''; }, 3000);
                }
            }, 2000);
        }
    });

    initTooltips();
</script>
</body>
</html>